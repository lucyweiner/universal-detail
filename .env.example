# Alternative to GOOGLE_APPLICATION_CREDENTIALS:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

TIME_ZONE=America/Phoenix
APPOINTMENT_DURATION_MINUTES=270
SLOT_INTERVAL_MINUTES=30
AVAILABILITY_KEYWORDS=available for details,available,availability,open

# Appointment summary emails
APPOINTMENT_SUMMARY_EMAIL=Universaldetailservices@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
